---
import { path } from '../utils/paths';
import ThemeToggle from './ThemeToggle.astro';
import { profile } from '../data/profile';

interface Props { current?: 'home' | 'research' | 'publications' | 'teaching' | 'timeline' | 'cv'; }
const { current } = Astro.props;

const nav = [
  { key: 'home',         label: 'Home',         href: '/' },
  { key: 'publications', label: 'Publications', href: '/publications' },
  { key: 'teaching',     label: 'Teaching',     href: '/teaching' },
  { key: 'timeline',     label: 'Timeline',     href: '/timeline' },
];
---
<header class="site-header">
  <div class="wrap row">
    <a class="logo" href={path('/')}>{profile.name.first}<span class="logo-dot">.</span></a>
    {/* CSS-only mobile menu: the checkbox holds open/closed state, the label is
        the burger button, and #nav-open:checked ~ nav reveals the dropdown. */}
    <input type="checkbox" id="nav-open" class="nav-open-box" aria-hidden="true" />
    <nav aria-label="Primary">
      <ul>
        {nav.map(n => (
          <li><a href={path(n.href)} aria-current={current === n.key ? 'page' : undefined}>{n.label}</a></li>
        ))}
      </ul>
    </nav>
    <label class="nav-burger" for="nav-open" aria-label="Toggle navigation menu">
      <svg class="i-burger" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16"></path>
      </svg>
      <svg class="i-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18"></path>
      </svg>
    </label>
    <ThemeToggle />
  </div>
</header>

<style>
.site-header{position:sticky;top:0;z-index:10;background:color-mix(in oklab,var(--bg) 86%,transparent);
  backdrop-filter:saturate(1.2) blur(8px);border-bottom:1px solid var(--border)}
.row{position:relative;display:flex;align-items:center;gap:1rem;height:3.6rem}
.logo{font-weight:800;letter-spacing:-.03em;color:var(--text);text-decoration:none;font-size:1.02rem}
.logo-dot{color:var(--accent)}
nav{margin-left:auto}
nav ul{display:flex;gap:1rem;list-style:none;margin:0;padding:0}
nav a{color:var(--muted);text-decoration:none;font-size:.86rem;font-weight:600}
nav a:hover{color:var(--text)}
nav a[aria-current="page"]{color:var(--accent)}

/* burger hidden on desktop; checkbox visually hidden everywhere but focusable */
.nav-open-box{position:absolute;width:1px;height:1px;opacity:0;pointer-events:none}
.nav-burger{display:none}

@media(max-width:760px){
  .nav-burger{
    display:inline-flex;align-items:center;justify-content:center;
    width:2.1rem;height:2.1rem;margin-left:auto;border-radius:9px;cursor:pointer;
    background:var(--surface);border:1px solid var(--border);color:var(--text);
  }
  .nav-burger .i-close{display:none}
  .nav-open-box:checked ~ .nav-burger .i-burger{display:none}
  .nav-open-box:checked ~ .nav-burger .i-close{display:inline}
  .nav-open-box:focus-visible ~ .nav-burger{outline:2px solid var(--accent);outline-offset:2px}

  nav{display:none;position:absolute;left:0;right:0;top:100%;margin:0;
    background:var(--bg);border-bottom:1px solid var(--border);
    padding:.8rem 1.25rem 1rem;box-shadow:0 12px 24px rgba(0,0,0,.18)}
  .nav-open-box:checked ~ nav{display:block}
  nav ul{flex-direction:column;gap:.75rem}
  nav a{font-size:.95rem;display:block}
}
</style>
