---
import { profile } from '../data/profile';
import { path } from '../utils/paths';
---
<section class="hero">
  <div class="wrap hero-row">
    <div class="hero-text">
      <h1>{profile.name.full}</h1>
      <div class="hero-bio">
        {profile.about.map(para => <p set:html={para} />)}
      </div>
    </div>
    <img class="hero-photo" src={path('/headshot_saiful.jpg')} alt={profile.name.full} width="280" height="391" loading="eager" />
  </div>
</section>

<style>
.hero{padding:4rem 0 3rem;border-bottom:1px solid var(--border)}
.hero-row{display:flex;gap:2.5rem;align-items:flex-start}
.hero-text{flex:1;min-width:0}
.hero h1{font-size:clamp(2.2rem,6vw,4rem);margin:.4rem 0 0}
.hero-bio{max-width:64ch;font-size:1.02rem;color:var(--text-body);margin-top:1.1rem}
.hero-bio p{margin:0}
.hero-bio p + p{margin-top:.9rem}
.hero-photo{width:280px;height:auto;flex-shrink:0;border-radius:var(--radius);
  border:1px solid var(--border);margin-top:.8rem}
@media(max-width:760px){
  .hero{padding:2.6rem 0 2rem}
  .hero-row{flex-direction:column-reverse;gap:1.4rem}
  .hero-photo{width:200px}
}
</style>
