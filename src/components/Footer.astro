---
import { profile } from '../data/profile';
import { path } from '../utils/paths';
import { visitorsSchema } from '../content/schemas';
import rawVisitors from '../data/visitors.json';

// Rendered at build time — every deploy stamps the footer with its build date.
const updated = new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const year = new Date().getFullYear();

// Scraper-resistant email display: no mailto link (a mailto href would still
// expose the raw address to harvesters).
const obfuscate = (email: string) => email.replace('@', 'AT').replace(/\./g, 'DOT');
const emails = [profile.contacts.email, profile.contacts.emailAlt].filter(Boolean).map(obfuscate);

const visitors = visitorsSchema.parse(rawVisitors);
---
<footer class="site-footer">
  <div class="wrap">
    <ul class="foot-emails">
      {emails.map(e => <li><span class="email">{e}</span></li>)}
    </ul>
    <ul class="foot-social">
      <li>
        <a href={profile.contacts.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" title="LinkedIn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19 0h-14c-2.76 0-5 2.24-5 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5v-14c0-2.76-2.24-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.27c-.97 0-1.75-.79-1.75-1.76s.78-1.76 1.75-1.76 1.75.79 1.75 1.76-.78 1.76-1.75 1.76zm13.5 12.27h-3v-5.6c0-3.37-4-3.11-4 0v5.6h-3v-11h3v1.77c1.4-2.59 7-2.78 7 2.48v6.75z"></path>
          </svg>
        </a>
      </li>
      <li>
        <a href={profile.contacts.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" title="GitHub">
          <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
          </svg>
        </a>
      </li>
      <li>
        <a href={profile.contacts.scholar} target="_blank" rel="noopener noreferrer" aria-label="Google Scholar" title="Google Scholar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 3 1 9l11 6 9-4.91V17h2V9L12 3zM5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82z"></path>
          </svg>
        </a>
      </li>
    </ul>
    <p class="muted built">© {year} {profile.name.full} · Built with Astro · Last updated {updated}{visitors.total > 0 && <> · <a href={path('/visitors')}>{visitors.total.toLocaleString('en-US')} visitors</a></>}</p>
  </div>
</footer>

<style>
.site-footer{margin-top:3rem;padding:2rem 0 3rem;border-top:1px solid var(--border)}
.foot-emails{list-style:none;padding:0;margin:0;display:flex;flex-wrap:wrap;gap:.3rem 1.2rem}
.foot-emails li{font-size:.9rem}
.email{color:var(--text-body)}
.foot-social{list-style:none;padding:0;margin:.8rem 0 0;display:flex;gap:.9rem}
.foot-social a{display:inline-flex;align-items:center;justify-content:center;color:var(--muted)}
.foot-social a:hover{color:var(--accent)}
.built{font-size:.78rem;margin-top:1.2rem}
</style>
