---
interface Props { course: { code: string; title: string; semesters: readonly string[]; descriptor: string; }; }
const { course } = Astro.props;
---
<article class="course card">
  <p class="code">{course.code}</p>
  <h3 class="ttl">{course.title}</h3>
  <p class="semesters muted">{course.semesters.join(' · ')}</p>
  <p class="desc">{course.descriptor}</p>
</article>

<style>
.course{display:flex;flex-direction:column}
.code{color:var(--accent);font-weight:800;margin:0;letter-spacing:.03em}
.ttl{font-size:1.02rem;margin:.3rem 0 .2rem}
.semesters{font-size:.8rem;margin:0}
.desc{font-size:.9rem;margin:.5rem 0 0;color:var(--text-body)}
</style>
