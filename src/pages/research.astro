---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import ResearchAreaCard from '../components/ResearchAreaCard.astro';
import CvTimeline from '../components/CvTimeline.astro';
import { profile } from '../data/profile';

const expItems = profile.experience.map(x => ({ period: x.period, title: x.role, org: x.org, detail: x.detail }));
---
<BaseLayout title="Research — Saiful Islam Salim" current="research">
  <Section title="Research" eyebrow="Focus areas">
    <div class="grid grid--2">
      {profile.researchAreas.map(a => <ResearchAreaCard area={a} />)}
    </div>
  </Section>
  <Section title="Experience" eyebrow="Where I've worked">
    <CvTimeline items={expItems} />
  </Section>
</BaseLayout>
